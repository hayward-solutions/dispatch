# Option 1: Single connection URL
DATABASE_URL=postgres://dispatch:dispatch@localhost:5433/dispatch?sslmode=disable

# Option 2: Individual fields (used when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5433
# DB_USER=dispatch
# DB_PASSWORD=dispatch
# DB_NAME=dispatch
# DB_SSLMODE=disable
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
ENCRYPTION_KEY=generate_with_make_keygen
SESSION_SECRET=generate_with_make_keygen
PORT=8080
BASE_URL=http://localhost:8080
LOG_LEVEL=debug
